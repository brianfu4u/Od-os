# ---------------------------------------------------------------------------
# Clearview OD — environment variables. Copy to .env for local dev.
# NEVER put real patient data (PHI) or production secrets in this file.
# For a hosted staging deploy, set these in the platform dashboards — see docs/DEPLOY.md.
# ---------------------------------------------------------------------------

# ── Database ──────────────────────────────────────────────────────────────
# OWNER role connection — used by migrations + seed (db:migrate / db:seed) and, in DEV ONLY, as the
# base the runtime derives clearview_login from. docker-compose.yml provisions this locally.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/clearview_od

# RUNTIME app connection — the least-privilege, non-superuser `clearview_login` role.
# REQUIRED in production (the app refuses to start without it). In dev it is derived from
# DATABASE_URL automatically, so you can leave it unset locally.
# APP_DATABASE_URL=postgresql://clearview_login:clearview_login_dev@localhost:5432/clearview_od
# Dev-only password used when deriving the clearview_login connection from DATABASE_URL.
# APP_DB_PASSWORD=clearview_login_dev
# Force TLS on/off in DEV only. Auto-on for non-local hosts (Neon/Supabase/Render), auto-off for
# localhost. In PRODUCTION this cannot disable TLS — the app always verifies (see DATABASE_CA_CERT).
# DATABASE_SSL=true

# ── Database TLS verification (P5.1) ────────────────────────────────────────
# In production the app ALWAYS connects with verification (rejectUnauthorized=true ⇒ chain + hostname
# checked) — a MITM cannot present an untrusted cert. DATABASE_CA_CERT is an OPTIONAL override: leave
# it unset to verify against the system/public CA store (Render / Neon / Supabase work out of the box),
# and set it only for a self-hosted / private CA to pin the trust chain. When set, inject the PEM via
# the environment ONLY — never commit a certificate. In dev, providing a CA switches the local
# connection to verification too. (Production refuses to start only if DATABASE_SSL=false.)
# DATABASE_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# ── API (NestJS) ────────────────────────────────────────────────────────────
API_PORT=3001            # local port; hosted platforms inject PORT, which takes precedence
NODE_ENV=development      # staging/prod set this to `production` (no dev shims, real sessions)
# CORS allow-list of web origins (comma-separated), e.g. https://app.example.com,https://admin.example.com
# In PRODUCTION this is REQUIRED and the app REFUSES TO START if it is empty, contains "*", or lists a
# non-origin value — production never reflects arbitrary origins and never uses a wildcard. In dev
# (unset) the API reflects the request origin for convenience. CORS_ALLOWED_ORIGINS is accepted as an
# alias for CORS_ORIGIN.
# CORS_ORIGIN=https://clearview-od.vercel.app

# ── Staging manager login (P5) ───────────────────────────────────────────────
# A minimal, env-gated, password-protected manager login for a PUBLIC staging env. It does NOT
# re-open the wide-open dev-login (that stays 404 in production). Leave disabled in real prod.
# STAGING_LOGIN_ENABLED=true
# STAGING_LOGIN_PASSWORD=change-me-to-a-long-random-string
# STAGING_TENANT_ID=11111111-1111-1111-1111-111111111111

# ── WeChat staff login (founder dependency; wx-login returns 501 until set) ──
# WX_APPID=
# WX_APPSECRET=

# ── LLM1 «Listen» layer (DeepSeek) ───────────────────────────────────────────
# Optional. When DEEPSEEK_API_KEY is set, LLM1 analyzes/classifies terminal reports with DeepSeek
# (OpenAI-compatible). When UNSET, LLM1 runs a deterministic keyword heuristic instead — so dev/CI
# work with no key. LLM1 only ever writes CLAIMS (claimed_state) + classifications; it NEVER writes
# verified_state (the deterministic cross-verification engine owns the verdict).
# DEEPSEEK_API_KEY=            # set in the Render dashboard for staging; never commit a real key
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
# LLM_LISTENER=heuristic       # pin to the heuristic adapter even when a key is present (optional)

# ── P7 · T4 Speech-to-Text (STT) ─────────────────────────────────────────────
# Provider-neutral. STT is a SEPARATE provider from LLM1/DeepSeek — do NOT reuse DEEPSEEK_API_KEY.
# When STT_API_KEY is set (STT_PROVIDER defaults to `openai`), uploaded voice clips are transcribed
# with OpenAI Whisper; the transcript lands as a derived field on the voice Document and is fed to
# LLM1. When UNSET, the keyless Null adapter marks each attempt `unavailable` — it NEVER fabricates
# text — and the audio is retained for a retry once a key is configured. Set the key in the Render
# dashboard for staging; never commit a real key.
# STT_PROVIDER=openai          # openai (default when a key is present) | mock (local/demo only) | (future) tencent | aliyun
# STT_API_KEY=                 # the STT provider key — independent of DEEPSEEK_API_KEY
# STT_BASE_URL=https://api.openai.com/v1
# STT_MODEL=whisper-1
# STT_LANGUAGE_DEFAULT=zh      # language hint when the source object carries none (zh | en | ja)
# STT_MIN_CONFIDENCE=0.5       # below this the transcript is marked low_confidence and not fed to LLM1
# STT_TIMEOUT_MS=30000
# STT_MOCK_TEXT=3号房已为下一位患者备好   # only used when STT_PROVIDER=mock

# ── Web (Next.js) — NEXT_PUBLIC_* are exposed to the browser ─────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001   # base URL of the deployed API
# NEXT_PUBLIC_STAGING=true   # staging: login form uses the password-gated staging login
