# ---------------------------------------------------------------------------
# Clearview OD — environment variables (copy to .env for local dev)
# NEVER put real patient data (PHI) or production secrets in this file.
# ---------------------------------------------------------------------------

# Postgres connection used by migrations, seed, and the API (dev owner role).
# docker-compose.yml provisions this exact database with the pgvector image.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/clearview_od

# API (NestJS)
API_PORT=3001
NODE_ENV=development

# Web (Next.js) — base URL of the API, exposed to the browser.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
